{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "almond",
  "name": "Magnora",
  "colors": {
    "primary": "#0C740E",
    "light": "#3FCB42",
    "dark": "#3FCB42"
  },
  "favicon": "/favicon.ico",
  "navigation": {
    "anchors": [
          {
            "anchor": "Help Center",
            "icon": "book-open",
            "pages": [
              "index", 
              {
                "group": "Getting started",
                "pages": [
                    "getting-started/adding-your-store",
                    {
                      "group": "Importing Reviews",
                      "pages": [
                          "getting-started/importing-reviews"
                      ]
                    },
                    "getting-started/send-a-campaign"
                ]
              },
              "theme"
            ]
          },
          {
            "anchor": "API Reference",
            "icon": "code",
            "pages": ["api/overview", "api/endpoints"]
          }
        ]
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "Dashboard",
        "href": "https://app.magnora.io"
      }
    ]
  },
  "contextual": {
    "options": [
     "copy",
     "view",
     "chatgpt",
     "claude",
     "perplexity",
     "mcp",
     "cursor",
     "vscode"
   ]
  },
  "footer": {
    
  },
  "background": {
    "color": {
      "light": "#F3F3F3",
      "dark": "#0C0E12"
    }
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter",
    "source": "https://app.magnora.io/fonts/InterVariable.woff2",
    "format": "woff2"
  },
  "css": "/custom.css"
}